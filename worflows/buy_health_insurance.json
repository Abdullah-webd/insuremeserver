{
  "workflow_id": "buy_health_insurance",
  "name": "Health Insurance Registration",
  "description": "Collect personal and health details to register for health insurance.",
  "policy_ref": "health_policy",
  "status": "in_progress",
  "current_step": 0,
  "steps": [
    {
      "id": "policy_ack",
      "field": "policy_understood",
      "type": "boolean",
      "prompt": "Do you understand and accept the Health Insurance policy terms?",
      "required": true
    },
    {
      "id": "full_name",
      "field": "full_name",
      "type": "string",
      "prompt": "What is your full name as it appears on your ID?",
      "required": true,
      "validation": { "min_length": 3 }
    },
    {
      "id": "gender",
      "field": "gender",
      "type": "string",
      "prompt": "What is your gender?",
      "required": false
    },
    {
      "id": "address",
      "field": "address",
      "type": "string",
      "prompt": "What is your home address?",
      "required": true
    },
    {
      "id": "phone",
      "field": "phone",
      "type": "string",
      "prompt": "What is your phone number?",
      "required": true,
      "validation": { "format": "phone_ng" }
    },
    {
      "id": "email",
      "field": "email",
      "type": "string",
      "prompt": "What is your email address?",
      "required": true,
      "validation": { "format": "email" }
    },
    {
      "id": "occupation",
      "field": "occupation",
      "type": "string",
      "prompt": "What is your occupation/job title?",
      "required": true
    },

    {
      "id": "date_of_birth",
      "field": "date_of_birth",
      "type": "string",
      "prompt": "What is your date of birth? (YYYY-MM-DD)",
      "required": true,
      "validation": { "format": "date" }
    },
    {
      "id": "current_health_condition",
      "field": "current_health_condition",
      "type": "string",
      "prompt": "How would you describe your current health condition?",
      "required": true
    },
    {
      "id": "pre_existing_conditions",
      "field": "pre_existing_conditions",
      "type": "string",
      "prompt": "Do you have any pre-existing conditions? If none, say 'None'.",
      "required": true
    },
    {
      "id": "hospital_visits",
      "field": "hospital_visits",
      "type": "string",
      "prompt": "Any previous hospital visits/admissions in the last 12 months? If none, say 'None'.",
      "required": false
    },
    {
      "id": "medications",
      "field": "medications",
      "type": "string",
      "prompt": "Are you currently taking any medications? If none, say 'None'.",
      "required": false
    },
    {
      "id": "lifestyle_habits",
      "field": "lifestyle_habits",
      "type": "string",
      "prompt": "Lifestyle habits (smoking/drinking/exercise). If none, say 'None'.",
      "required": false
    },
    {
      "id": "preferred_hospital",
      "field": "preferred_hospital",
      "type": "string",
      "prompt": "Do you have a preferred hospital/doctor? If yes, tell us. If no, say 'No preference'.",
      "required": false
    },
    {
      "id": "next_of_kin",
      "field": "next_of_kin",
      "type": "string",
      "prompt": "Please provide your next of kin full name.",
      "required": true
    },
    {
      "id": "next_of_kin_phone",
      "field": "next_of_kin_phone",
      "type": "string",
      "prompt": "Next of kin phone number.",
      "required": true,
      "validation": { "format": "phone_ng" }
    },
    {
      "id": "documents",
      "field": "documents",
      "type": "array",
      "prompt": "Please upload any supporting medical documents (if any). You can upload images or PDFs.",
      "required": false
    },
    {
      "id": "evidence",
      "field": "evidence",
      "type": "array",
      "prompt": "Please upload any additional evidence (photos/videos/documents).",
      "required": true,
      "validation": { "min_items": 1 }
    }
  ],
  "collected_fields": {
    "policy_understood": null,
    "full_name": null,
    "gender": null,
    "address": null,
    "phone": null,
    "email": null,
    "occupation": null,
    "date_of_birth": null,
    "current_health_condition": null,
    "pre_existing_conditions": null,
    "hospital_visits": null,
    "medications": null,
    "lifestyle_habits": null,
    "preferred_hospital": null,
    "next_of_kin": null,
    "next_of_kin_phone": null,
    "documents": [],
    "evidence": []
  },
  "verification": {},
  "submit": {
    "ready": false,
    "function": "submit_health_insurance_application",
    "payload_field": "health_data"
  }
}
