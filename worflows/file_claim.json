{
  "workflow_id": "file_claim",
  "name": "File Claim",
  "description": "Collect claim details for review by the admin team.",
  "status": "in_progress",
  "current_step": 0,
  "steps": [
    {
      "id": "policy_type",
      "field": "policy_type",
      "type": "string",
      "prompt": "Which policy are you filing a claim for? (car, house, health, life)",
      "required": true,
      "validation": { "enum": ["car", "house", "health", "life"] }
    },
    {
      "id": "incident_date",
      "field": "incident_date",
      "type": "string",
      "prompt": "When did the incident happen? (YYYY-MM-DD)",
      "required": true,
      "validation": { "format": "date" }
    },
    {
      "id": "incident_description",
      "field": "incident_description",
      "type": "string",
      "prompt": "Please describe what happened in detail.",
      "required": true,
      "validation": { "min_length": 10 }
    },
    {
      "id": "evidence",
      "field": "evidence",
      "type": "array",
      "prompt": "Please upload supporting evidence (photos, reports, receipts).",
      "required": true,
      "validation": { "min_items": 1 }
    }
  ],
  "collected_fields": {
    "policy_type": null,
    "incident_date": null,
    "incident_description": null,
    "evidence": []
  },
  "submit": {
    "ready": false,
    "function": "submit_claim",
    "payload_field": "claim_data"
  }
}
