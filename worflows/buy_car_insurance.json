{
  "workflow_id": "buy_car_insurance",
  "name": "Car Insurance Registration",
  "description": "Collect car and owner details to register for car insurance.",
  "policy_ref": "car_policy",
  "status": "in_progress",
  "current_step": 0,
  "steps": [
    {
      "id": "policy_ack",
      "field": "policy_understood",
      "type": "boolean",
      "prompt": "Do you understand and accept the Car Insurance policy terms?",
      "required": true
    },
    {
      "id": "full_name",
      "field": "full_name",
      "type": "string",
      "prompt": "What is your full name as it appears on your ID?",
      "required": true,
      "validation": { "min_length": 3 }
    },
    {
      "id": "date_of_birth",
      "field": "date_of_birth",
      "type": "string",
      "prompt": "What is your date of birth? (e.g., 1998-04-12)",
      "required": true
    },
    {
      "id": "gender",
      "field": "gender",
      "type": "string",
      "prompt": "What is your gender?",
      "required": false
    },
    {
      "id": "address",
      "field": "address",
      "type": "string",
      "prompt": "What is your home address?",
      "required": true
    },
    {
      "id": "occupation",
      "field": "occupation",
      "type": "string",
      "prompt": "What is your occupation/job title?",
      "required": true
    },
    {
      "id": "phone",
      "field": "phone",
      "type": "string",
      "prompt": "What is your phone number?",
      "required": true,
      "validation": { "format": "phone_ng" }
    },
    {
      "id": "email",
      "field": "email",
      "type": "string",
      "prompt": "What is your email address?",
      "required": true,
      "validation": { "format": "email" }
    },

    {
      "id": "car_make",
      "field": "car_make",
      "type": "string",
      "prompt": "What is the car make (e.g., Toyota)?",
      "required": true
    },
    {
      "id": "car_model",
      "field": "car_model",
      "type": "string",
      "prompt": "What is the car model (e.g., Corolla)?",
      "required": true
    },
    {
      "id": "car_year",
      "field": "car_year",
      "type": "string",
      "prompt": "What is the car year (e.g., 2020)?",
      "required": true,
      "validation": { "format": "year" }
    },
    {
      "id": "car_value",
      "field": "car_value",
      "type": "number",
      "prompt": "What is the estimated value of the car in Naira?",
      "required": true
    },
    {
      "id": "vin",
      "field": "vin",
      "type": "string",
      "prompt": "What is the Vehicle Identification Number (VIN)? If you don't know it, type \"I don't know\".",
      "required": false
    },
    {
      "id": "driver_license_number",
      "field": "driver_license_number",
      "type": "string",
      "prompt": "What is your driver's license number?",
      "required": true
    },
    {
      "id": "driving_history",
      "field": "driving_history",
      "type": "string",
      "prompt": "Briefly describe your driving history (any accidents/violations in the last 3 years)? If none, type \"none\".",
      "required": true
    },
    {
      "id": "vehicle_usage",
      "field": "vehicle_usage",
      "type": "string",
      "prompt": "How do you use the car? (personal, business, ride-hailing)",
      "required": true
    },
    {
      "id": "vehicle_location",
      "field": "vehicle_location",
      "type": "string",
      "prompt": "Where is the car mostly used/parked? (city/area)",
      "required": true
    },
    {
      "id": "ownership_age",
      "field": "ownership_age",
      "type": "number",
      "prompt": "How many years have you owned this car?",
      "required": true
    },
    {
      "id": "condition",
      "field": "condition",
      "type": "string",
      "prompt": "What is the condition of the car (Excellent, Good, Fair, Poor)?",
      "required": true
    },
    {
      "id": "plate_number",
      "field": "plate_number",
      "type": "string",
      "prompt": "What is your car plate number?",
      "required": true,
      "validation": { "format": "plate_ng" },
      "verification_required": true,
      "verification_action": "verify_plate"
    },
    {
      "id": "car_image",
      "field": "car_image",
      "type": "image",
      "prompt": "Please upload clear photos of the car (front, back, side).",
      "required": true,
      "verification_required": true,
      "verification_action": "verify_image_openai"
    },
    {
      "id": "documents",
      "field": "documents",
      "type": "array",
      "prompt": "Please upload any supporting documents (e.g., vehicle registration papers, driver’s license scan). You can upload images or PDFs.",
      "required": false
    },
    {
      "id": "evidence",
      "field": "evidence",
      "type": "array",
      "prompt": "Please upload any additional evidence (photos/videos/documents).",
      "required": true,
      "validation": { "min_items": 1 }
    }
  ],
  "collected_fields": {
    "policy_understood": null,
    "full_name": null,
    "date_of_birth": null,
    "gender": null,
    "address": null,
    "phone": null,
    "email": null,
    "occupation": null,
    "car_make": null,
    "car_model": null,
    "car_year": null,
    "car_value": null,
    "vin": null,
    "driver_license_number": null,
    "driving_history": null,
    "vehicle_usage": null,
    "vehicle_location": null,
    "ownership_age": null,
    "condition": null,
    "plate_number": null,
    "car_image": null,
    "documents": [],
    "evidence": []
  },
  "verification": {
    "plate_number": { "required": true, "status": "pending", "provider": "openai_vision" },
    "car_image": { "required": true, "status": "pending", "provider": "openai_vision" }
  },
  "submit": {
    "ready": false,
    "function": "submit_car_insurance_application",
    "payload_field": "car_data"
  }
}
