{
  "workflow_id": "buy_house_insurance",
  "name": "House Insurance Registration",
  "description": "Collect property and owner details to register for house insurance.",
  "policy_ref": "house_policy",
  "status": "in_progress",
  "current_step": 0,
  "steps": [
    {
      "id": "policy_ack",
      "field": "policy_understood",
      "type": "boolean",
      "prompt": "Do you understand and accept the House Insurance policy terms?",
      "required": true
    },
    {
      "id": "full_name",
      "field": "full_name",
      "type": "string",
      "prompt": "What is your full name as it appears on your ID?",
      "required": true,
      "validation": { "min_length": 3 }
    },
    {
      "id": "date_of_birth",
      "field": "date_of_birth",
      "type": "string",
      "prompt": "What is your date of birth? (e.g., 1998-04-12)",
      "required": true
    },
    {
      "id": "gender",
      "field": "gender",
      "type": "string",
      "prompt": "What is your gender?",
      "required": false
    },
    {
      "id": "address",
      "field": "address",
      "type": "string",
      "prompt": "What is your residential address?",
      "required": true
    },
    {
      "id": "phone",
      "field": "phone",
      "type": "string",
      "prompt": "What is your phone number?",
      "required": true,
      "validation": { "format": "phone_ng" }
    },
    {
      "id": "email",
      "field": "email",
      "type": "string",
      "prompt": "What is your email address?",
      "required": true,
      "validation": { "format": "email" }
    },
    {
      "id": "occupation",
      "field": "occupation",
      "type": "string",
      "prompt": "What is your occupation/job title?",
      "required": true
    },

    {
      "id": "property_address",
      "field": "property_address",
      "type": "string",
      "prompt": "What is the property address?",
      "required": true
    },
    {
      "id": "property_type",
      "field": "property_type",
      "type": "string",
      "prompt": "What type of property is it? (e.g., bungalow, duplex, apartment)",
      "required": true
    },
    {
      "id": "property_value",
      "field": "property_value",
      "type": "number",
      "prompt": "Estimated value of the property (in NGN).",
      "required": true,
      "validation": { "min": 1 }
    },
    {
      "id": "property_year_built",
      "field": "property_year_built",
      "type": "string",
      "prompt": "What year was the property built? (e.g., 2015) If unknown, type \"unknown\".",
      "required": false
    },
    {
      "id": "property_condition",
      "field": "property_condition",
      "type": "string",
      "prompt": "What is the current condition of the building? (Excellent, Good, Fair, Poor)",
      "required": true
    },
    {
      "id": "security_features",
      "field": "security_features",
      "type": "string",
      "prompt": "What security features does the property have? (e.g., gate, CCTV, guards) If none, type \"none\".",
      "required": false
    },
    {
      "id": "area_risks",
      "field": "area_risks",
      "type": "string",
      "prompt": "Are there any known risks in the area (flood, fire, theft)? If none, type \"none\".",
      "required": false
    },
    {
      "id": "contents_value",
      "field": "contents_value",
      "type": "number",
      "prompt": "Estimated value of contents inside (furniture/electronics) in NGN. If not sure, estimate.",
      "required": false
    },
    {
      "id": "ownership_age",
      "field": "ownership_age",
      "type": "number",
      "prompt": "How many years have you owned this property?",
      "required": true
    },
    {
      "id": "condition",
      "field": "condition",
      "type": "string",
      "prompt": "What is the condition of the property (Excellent, Good, Fair, Poor)?",
      "required": true
    },
    {
      "id": "property_images",
      "field": "property_images",
      "type": "array",
      "prompt": "Please upload recent images of the property.",
      "required": true,
      "validation": { "min_items": 1 },
      "verification_required": true,
      "verification_action": "verify_image_openai"
    },
    {
      "id": "documents",
      "field": "documents",
      "type": "array",
      "prompt": "Please upload any supporting documents (e.g., utility bill, deed/tenancy agreement). You can upload images or PDFs.",
      "required": false
    },
    {
      "id": "evidence",
      "field": "evidence",
      "type": "array",
      "prompt": "Please upload any additional evidence (photos/videos/documents).",
      "required": true,
      "validation": { "min_items": 1 }
    }
  ],
  "collected_fields": {
    "policy_understood": null,
    "full_name": null,
    "date_of_birth": null,
    "gender": null,
    "address": null,
    "phone": null,
    "email": null,
    "occupation": null,
    "property_address": null,
    "property_type": null,
    "property_value": null,
    "property_year_built": null,
    "property_condition": null,
    "security_features": null,
    "area_risks": null,
    "contents_value": null,
    "ownership_age": null,
    "condition": null,
    "property_images": [],
    "documents": [],
    "evidence": []
  },
  "verification": {
    "property_images": { "required": true, "status": "pending", "provider": "openai_vision" }
  },
  "submit": {
    "ready": false,
    "function": "submit_house_insurance_application",
    "payload_field": "house_data"
  }
}
